<% provide(:title, "Log in") %>
<h1>Log in</h1>

<div class="row">
  <div class="col-md-6 col-md-offset-3">
    <%= form_for(:session) do |f| %>

      <%= f.label :name %>
      <%= f.text_field :name, class: 'form-control' %>

      <%= f.label :password %>
      <%= f.password_field :password, class: 'form-control' %>

      <%= f.submit "Log in", class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<style>

    html {
      height: 100%;
    }

    .row {
      height: 100%;
    }

    body {
    height: 100%;
    }

    h1 {
    margin-top: 0;
    margin-bottom: .5rem;
    font-weight: 500;
    line-height: 1.2;
    }

    .col-md-6 {
    display: flex;
    flex-wrap: wrap;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0.5rem 1rem rgba(0,0,0,.15) !important;
    }

    .col-md-offset-3 {
    box-sizing: border-box;
    max-width: 1320px;
    width: 100%;
    height: 50%;
    margin-right: auto;
    margin-left: auto;
    }

    label {
    font-size: 1.5rem;
    }

    form {
    width: 50%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    }

    .btn {
    width: 20%;
    height: 10%;
    background-color: dodgerblue;
    }

    .form-control {
    margin: 1rem 0;
    height: 10%;
    }

</style>