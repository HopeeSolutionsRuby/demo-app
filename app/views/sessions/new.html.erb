<div class="d-flex justify-content-center">
  <div class="w-50">
    <!-- Pills navs -->
    <ul class="nav nav-pills nav-justified mb-3" id="ex1" role="tablist">
      <li class="nav-item" role="presentation">
        <a class="nav-link active" id="tab-login" data-mdb-toggle="pill" role="tab"
          aria-controls="pills-login" aria-selected="true">Login</a>
      </li>
      <li class="nav-item" role="presentation">
        <a class="nav-link" id="tab-register" data-mdb-toggle="pill" role="tab"
          aria-controls="pills-register" aria-selected="false">Register</a>
      </li>
    </ul>
    <!-- Pills navs -->

    <!-- Pills content -->
    <div class="tab-content">
      <div class="tab-pane fade show active" id="pills-login" role="tabpanel" aria-labelledby="tab-login">
        <%= render 'login' %>
      </div>
      <div class="tab-pane fade" id="pills-register" role="tabpanel" aria-labelledby="tab-register">
        <%= render 'register' %>
      </div>
    </div>
    <!-- Pills content -->
  </div>
</div>
<script>
  function classToggleLogin() {
    document.querySelector('#pills-login').className =('tab-pane fade show active');
    document.querySelector('#tab-login').className =('nav-link active');

    document.querySelector('#pills-register').className = ('tab-pane fade');
    document.querySelector('#tab-register').className =('nav-link');

  }
  function classToggleRegister() {
    document.querySelector('#pills-login').className = ('tab-pane fade');
    document.querySelector('#pills-register').className = ('tab-pane fade show active');
    document.querySelector('#tab-login').className =('nav-link');
    document.querySelector('#tab-register').className =('nav-link active');
  }
  document.querySelector('#tab-login').addEventListener('click', classToggleLogin);
  document.querySelector('#tab-register').addEventListener('click', classToggleRegister);
</script>
