<%= javascript_include_tag 'products' %>
<h3>PRODUCTS TABLE</h3>
<table class="product">
  <thead>
    <tr>
      <th>#</th>
      <th>ID</th>
      <th>Product</th>
      <th>Price</th>
      <th>Quantity</th>
      <th>Category</th>
      <td>Detail</td>
    </tr>
  </thead>
  <tbody>
    <% @products.each_with_index do |product, index| %>
      <tr>
        <td><%= index + 1 %></td>
        <td><%= product.id %></td>
        <td><%= product.name %></td>
        <td><%= product.price %></td>
        <td><%= product.quantity %></td>
        <td><%= product.category.name %></td>
        <td><%= link_to 'Show', product %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<button class="ajax-link">click me</button>
<nav aria-label="Page navigation">
  <ul class="pagination">
    <li class="page-item"><a class="page-link page-link-ajax" href="<%= products_path(page: 1) %>"><%="First"%></a></li>
    <% @displayed_pages.each do |page| %>
      <li class="page-item"><a class="page-link page-link-ajax" href="<%= products_path(page: page) %>"><%= page %></a></li>
    <% end %>
    <li class="page-item"><a class="page-link page-link-ajax" href="<%= products_path(page: @total_pages) %>"><%="Last"%></a></li>
  </ul>
</nav>