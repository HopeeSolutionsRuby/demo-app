<head>
  <%= stylesheet_link_tag 'application', media: 'all' %>
</head>
<body>
  <header>
    Header
  </header>
  <nav></nav>
  <section class="container">
    <%= link_to "New Products", new_product_path %>
    <%= search_form_for @q do |f| %>
      <%= f.label :name_cont, "Product name" %>
      <%= f.search_field :name_cont %>
      <%= f.label :price_gt, "Price >" %>
      <%= f.search_field :price_gt %>
      <%= f.submit "Search" %>
    <% end %>
    <%= link_to "New Products", new_product_path %>
    <div id="product-container">
      <%= render 'products_table' %>
    </div>
  </section>
  <aside></aside>
  <footer class="footer">
    This is footer
  </footer>
</body>

