<% provide(:title, @user.email) %>
<div class="row">
  <aside class="col-md-4">
    <section class="user_info">
      <h1>
        Welcome <%= @user.email %>
      </h1>
      <!-- <td>< link_to "Profile", profile_path(@user) %></td> -->
      <td><%= link_to "Log out", destroy_user_session_path, method: "delete", data: { confirm: "Are you sure?" }, class: "btn btn-primary", redirect_to: user_session_path %></td>

      <td><%= link_to "Change Password", edit_user_password_path %></td>
    </section>
  </aside>
</div>
