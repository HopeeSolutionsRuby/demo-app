<h1>Detail User</h1>
<h4>Name: <%= @user&.name %></h4>
<h4>Email: <%= @user&.email %></h4>
<h4>Total Post: <%=@user&.posts.size %></h4>
<%= link_to "New Post", new_user_post_path(@user), class: 'btn btn-primary' %>

<%= render partial: 'shared/flash' %>
<table class="table table-striped">
    <thead>
    <tr>
      <th>Title</th>
      <th>Content</th>
      <th colspan="3"></th>
    </tr>
  </thead>

   <tbody>
    <% @user.posts.order(updated_at: :desc).each do |post| %>
      <tr>
        <td><%= post.title %></td>
        <td class="text-truncate" style="max-width: 150px;"><%= post.content %></td>
        <td><%= link_to "Show", user_post_path(@user, post), class: 'btn btn-primary' %></td>
        <td><%= link_to "Edit", edit_user_post_path(@user, post),class: 'btn btn-info' %></td>
        <td><%= button_to "Destroy", user_post_path(@user, post), method: 'delete' ,class: 'btn btn-danger' %></td>
      </tr>
    <% end %>
  </tbody>
</table>
