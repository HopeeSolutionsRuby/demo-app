<% provide(:title, @user.name) %>
<div class="row">
  <aside class="col-md-4">
    <section class="user_info">
      <h1>
        Welcome <%= @user.name %>
      </h1>
      <td><%= link_to "Profile", profile_path(@user) %></td>
      <td><%= link_to "Log out", logout_path, method: "delete" %></td>
      <td><%= link_to "Change Password", edit_pass_word_reset_url %></td>
    </section>
  </aside>
</div>
