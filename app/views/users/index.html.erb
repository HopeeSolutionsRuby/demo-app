<h1>User</h1>

<%= render partial: 'shared/flash' %>

<%= link_to "New User", new_user_path, class: "btn btn-primary" %>
<%= render partial:'shared/search', locals: { type: 'name_or_email_cont'} %>
<table class="table table-striped">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Total Post</th>
      <th colspan="3"></th>
    </tr>
  </thead>

   <tbody>
    <% @users&.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td><%= user&.posts_count || 0 %></td>
        <td><%= link_to "Show", user, class: 'btn btn-primary' %></td>
        <td><%= link_to "Edit", edit_user_path(user),class: 'btn btn-info' %></td>
        <td><%= button_to "Destroy", user, method: 'delete' ,class: "btn btn-danger" %></td>
      </tr>
    <% end %> 
  </tbody>
</table>
<%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
