<div class="col-lg-10">
	<div class="card bg-dark bg-gradient text-white rounded-0 shadow my-3">
		<div class="card-body">
			<p><% notice %></p>
			<h1>Student Details</h1>
			<p><strong>First Name: </strong><%= @student.first_name%></p>
			<p><strong>Last Name: </strong><%= @student.last_name%></p>
			<p><strong>Classroom: </strong><%= @student.class_room.name%></p>
			<p><strong>Age: </strong><%= @student.age%></p>
			<p><strong>Address: </strong><%= @student.address%></p>
			<p><strong>City: </strong><%= @student.city%></p>
			<p><strong>Province: </strong><%= @student.province%></p>
			<p><strong>Email: </strong><%= @student.email%></p>
		</div>
	</div>
</div>
<%= link_to 'Back', students_path, class: 'btn btn-primary' %>
