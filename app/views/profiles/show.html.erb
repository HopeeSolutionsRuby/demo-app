<% provide(:title, @user.name) %>
<div class="row">
  <aside class="col-md-4">
    <section class="user_info">
      <% if @profile %>
        <h1>
          Welcome <%= @user.name %>
        </h1>
        <td><%= @profile.sex %></td>
      <% else %>
        <h1>Your profile doesn't exist</h1>
      <% end %>
    </section>
  </aside>
</div>
